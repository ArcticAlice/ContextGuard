OPENAI_API_KEY=your_openai_key
PORT=3000
# Required hackathon model. Change only if your account exposes a different GPT-5.6 snapshot.
GPT_MODEL=gpt-5.6
# Optional: enables the Slack channel-name preview in the dashboard.
SLACK_USER_TOKEN=xoxp-your-read-only-token
# Gmail OAuth: download this Web application credential JSON from Google Cloud Console.
GMAIL_CREDENTIALS_PATH=credentials.json
# OAuth callback registered in Google Cloud Console.
GMAIL_REDIRECT_URI=http://localhost:3000/api/gmail/oauth2callback
